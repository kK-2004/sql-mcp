MYSQL_URL=mysql://root:123456@127.0.0.1:3306/test_db
# Or use split fields instead of MYSQL_URL:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=123456
# MYSQL_DATABASE=test_db

# Optional: SSH tunnel for remote DB access
SSH_ENABLED=false
# SSH_HOST=1.2.3.4
# SSH_PORT=22
# SSH_USER=ubuntu
# Use one of password or private key
# SSH_PASSWORD=your_ssh_password
# SSH_PRIVATE_KEY_PATH=/Users/kk/.ssh/id_rsa
# SSH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----
# SSH_PASSPHRASE=your_key_passphrase
# Optional tunnel endpoints (defaults: dst host/port use MySQL host/port, local 127.0.0.1:0)
# SSH_DST_HOST=127.0.0.1
# SSH_DST_PORT=3306
# SSH_LOCAL_HOST=127.0.0.1
# SSH_LOCAL_PORT=0

# Required: whitelist tables LLM can access ("*" means all tables, high risk)
ALLOWED_TABLES=users,orders

# Optional: allowed actions, default connect,schema,query,insert,delete
ALLOWED_METHODS=connect,schema,query,insert,delete

# Optional limits for query
DEFAULT_LIMIT=100
MAX_LIMIT=1000

# Optional safety switch for delete
ALLOW_EMPTY_DELETE=false
