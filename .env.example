# MySQL Configuration (default mode)
#MYSQL_URL=mysql://root:123456@127.0.0.1:3306/test_db
#MYSQL_HOST=127.0.0.1
#MYSQL_PORT=3306
#MYSQL_USER=root
#MYSQL_PASSWORD=123456
#MYSQL_DATABASE=test_db

# SQLite Configuration
SQLITE_DB_PATH=/path/to/database.sqlite
# Optional: SSH tunnel for remote MySQL access
SSH_ENABLED=false
SSH_HOST=1.2.3.4
SSH_PORT=22
SSH_USER=ubuntu
SSH_PASSWORD=your_ssh_password
# SSH_PRIVATE_KEY_PATH=/Users/kk/.ssh/id_rsa
# Required: whitelist tables LLM can access ("*" means all tables)
ALLOWED_TABLES=users,orders
# Optional: allowed actions, default connect,schema,query,insert,delete
ALLOWED_METHODS=connect,schema,query,insert,delete
# Optional limits for query
DEFAULT_LIMIT=100
MAX_LIMIT=1000
# Optional safety switch for delete
ALLOW_EMPTY_DELETE=false
